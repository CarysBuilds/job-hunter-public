# Optional advanced configuration.
# Most users should configure Job Hunter from the web setup screen.

PORT=3000
APP_HOST=127.0.0.1

# Windows default data dir is %APPDATA%\JobHunter\data.
# Set APP_DATA_DIR only for development or portable runs.
# APP_DATA_DIR=./data

# OpenAI-compatible LLM API. Leave disabled until configured.
LLM_ENABLED=false
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=20000

# Crawler settings. Real platform access is always user-triggered.
CRAWL_HEADLESS=false
CRAWL_PAGES=1
CRAWL_DELAY_MIN_MS=3000
CRAWL_DELAY_MAX_MS=8000
CRAWL_KEYWORDS=
CRAWL_CITY_CODE=101010100

# Chrome CDP ports for isolated platform profiles.
BOSS_CDP_PORT=9222
LIEPIN_CDP_PORT=9223
ZHAOPIN_CDP_PORT=9224

# Lifecycle archive rules by score grade.
ARCHIVE_A_DAYS=30
ARCHIVE_B_DAYS=21
ARCHIVE_C_DAYS=14
ARCHIVE_D_DAYS=7

# Liepin/Zhaopin detail pages are more sensitive to rate limits.
LIEPIN_FETCH_DETAILS=false
LIEPIN_AUTO_DETAIL_LIMIT=30
ZHAOPIN_FETCH_DETAILS=false
ZHAOPIN_AUTO_DETAIL_LIMIT=30
